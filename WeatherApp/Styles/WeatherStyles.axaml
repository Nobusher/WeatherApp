<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

  <!-- Add Styles Here -->
  <Style Selector="Border.weather-card">
      <Setter Property="Background">
          <Setter.Value>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                  <GradientStop Color="#69b4fa" Offset="0"/>
                   <GradientStop Color="#d5e3f0" Offset="1"/>
              </LinearGradientBrush>
          </Setter.Value>
      </Setter>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="32"/>
      <Setter Property="Width" Value="320"/>
  </Style>
    <Style Selector="TextBlock.city">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.temperature">
        <Setter Property="FontSize" Value="64"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>
    <Style Selector="Separator.divider">
        <Setter Property="Margin" Value="0,16"/>
         <Setter Property="Background">
          <Setter.Value>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                  <GradientStop Color="#11518c" Offset="0"/>
                   <GradientStop Color="#7a8a99" Offset="1"/>
              </LinearGradientBrush>
          </Setter.Value>
      </Setter>
        <Setter Property="Height" Value="8"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="TextBlock.wind">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>
    <Style Selector="TextBlock.status">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="#cdd6f4"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
   <Style Selector="Window">
       <Setter Property="Background">
           <Setter.Value>
               <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                  <GradientStop Color="#175fa3" Offset="0"/>
                   <GradientStop Color="#456787" Offset="1"/>
              </LinearGradientBrush>
           </Setter.Value>
       </Setter>
   </Style>
</Styles>
